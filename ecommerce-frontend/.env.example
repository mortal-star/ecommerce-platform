# API base URL prefix used by axios.
# In development, requests go through the Vite proxy: any request to /api/*
# is forwarded to http://localhost:8080 (which serves the Spring Boot backend
# under its own /api context-path). Set to a fully qualified URL in production
# (e.g. https://api.example.com/api) when the frontend is hosted separately.
VITE_API_BASE_URL=/api
